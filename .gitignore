# --- PyInstaller build output ---
# frontend/dist is tracked on purpose (it's source, not a build artifact) -
# only the PyInstaller output directories are ignored. Build with
# `pyinstaller --distpath exe-dist ...` to avoid any path collision.
exe-dist/
*.spec
backend/build/
build/
exe-dist/
*.spec
